{
  "hyprland/workspaces": {
    "all-outputs": false,
    "warp-on-scroll": true,
    "format": "{name}",
    "persistent-only": false,
    "active-only": false,
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": []
    }
  },

  "custom/swaync": {
    "tooltip": true,
    "format": "{icon}",
    "format-icons": {
      "notification": "ïƒ³<span foreground='#f38ba8'><sup>+</sup></span>",
      "none": "ïƒ³",
      "dnd-none": "ï‡¶",
      "dnd-notification": "ï‡¶<span foreground='#f38ba8'><sup>+</sup></span>"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "sleep 0.1 && swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },

  "hyprland/window": {
    "format": "{}",
    "rewrite": {
      "": "Desktop"
    },
    "max-length": 60,
    "ellipsize": true,
    "separate-outputs": false,
    "icon-size": 0
  },

  "tray": {
    "icon-size": 16,
    "spacing": 4,
    "show-passive-items": false,
    "expand": false
  },

  "clock": {
    "format": "{:%I:%M %p}",
    "tooltip-format": "<big>{:%Y-%m-%d %H:%M:%S}</big>",
    "interval": 1
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "َ°‌ں  muted",
    "format-bluetooth": "َ°‚¯ {volume}%",
    "format-bluetooth-muted": "َ°‚¯ َ°‌ں",
    "format-icons": {
      "headphone": "َ°‹‹",
      "hands-free": "َ°‹ژ",
      "headset": "َ°‹ژ",
      "phone": "َ°ڈ²",
      "portable": "َ°ڈ²",
      "car": "َ°„‹",
      "default": ["َ°•؟", "َ°–€", "َ°•¾"]
    },
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pavucontrol",
    "on-click-middle": "pavucontrol",
    "scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%",
    "smooth-scrolling-threshold": 0.5,
    "tooltip": true,
    "tooltip-format": "{desc} ({format_source})",
    "ignored-sinks": ["Easy Effects Sink"]
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-full": "{icon}  {capacity}%",
    "format-charging": "ïƒ§  {capacity}%",
    "format-plugged": "ï‡¦  {capacity}%",
    "format-alt": "{time}  {icon}",
    "format-icons": ["ï‰„", "ï‰ƒ", "ï‰‚", "ï‰پ", "ï‰€"]
  },

  "network": {
    "interval": 5,
    "format-wifi": "{icon}  {essid} ({signalStrength}%)",
    "format-ethernet": "َ°ˆ€ {ifname}",
    "format-disconnected": "َ°¤¯  Disconnected",
    "format-disabled": "َ°–© Wi-Fi Off",
    "format-linked": "َ°ˆ€ Wired (No IP)",
    "format-vpn": "ï€£ VPN ({ifname})",
    "tooltip": true,
    "tooltip-format-wifi": "WiFi: {essid} ({signalStrength}%)\nIP: {ipaddr}/{cidr}\nUp: {bandwidthUpBytes} | Down: {bandwidthDownBytes}",
    "tooltip-format-ethernet": "Ethernet: {ifname}\nIP: {ipaddr}/{cidr}\nUp: {bandwidthUpBytes} | Down: {bandwidthDownBytes}",
    "tooltip-format-vpn": "VPN: {vpn_name} ({ipaddr})",
    "tooltip-format-disconnected": "No Network Connection",
    "tooltip-format-disabled": "Wi-Fi Disabled",
    "format-icons": {
      "wifi": ["َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"],
      "ethernet": "َ°ˆ€",
      "disconnected": "َ°¤¯",
      "disabled": "َ°–©",
      "vpn": "ï€£"
    },
    "on-click": "~/.config/waybar/scripts/wifi.sh --menu"
  }
}
