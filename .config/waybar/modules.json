{
  "hyprland/workspaces": {
    "all-outputs": false,
    "output": "",
    "warp-on-scroll": true,
    "format": "{name}",
    "persistent-only": false,
    "active-only": false,
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": []
    }
  },

  "custom/swaync": {
    "tooltip": true,
    "format": "{icon}",
    "format-icons": {
      "notification": "ïƒ³<span foreground='#f38ba8'><sup>+</sup></span>",
      "none": "ïƒ³",
      "dnd-none": "ï‡¶",
      "dnd-notification": "ï‡¶<span foreground='#f38ba8'><sup>+</sup></span>"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client --subscribe-waybar",
    "on-click": "swaync-client --toggle-panel",
    "on-click-right": "swaync-client --toggle-dnd",
    "escape": true
  },

  "hyprland/window": {
    "format": "{}",
    "rewrite": {
      "": "Desktop"
    },
    "max-length": 60,
    "ellipsize": true,
    "separate-outputs": false,
    "icon-size": 0
  },

  "tray": {
    "icon-size": 16,
    "spacing": 4,
    "show-passive-items": false,
    "expand": false
  },

  "bluetooth": {
    "format": "َ°‚²",
    "format-connected": "َ°‚¯ {device_alias}",
    "format-disabled": "َ°‚²",
    "tooltip-format": "{num_connections} connected\n{device_address}",
    "on-click": "/home/jllyn/.config/rofi/scripts/bluetooth-manager",
    "persist": true
  },

  "clock": {
    "format": "{:%I:%M %p}",
    "tooltip-format": "<big>{:%Y-%m-%d %H:%M:%S}</big>\n<tt>{calendar}</tt>",
    "interval": 1
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "َ°‌ں  muted",
    "format-bluetooth": "َ°‚¯ {volume}%",
    "format-bluetooth-muted": "َ°‚¯ َ°‌ں",
    "format-icons": {
      "headphone": "َ°‹‹",
      "hands-free": "َ°‹ژ",
      "headset": "َ°‹ژ",
      "phone": "َ°ڈ²",
      "portable": "َ°ڈ²",
      "car": "َ°„‹",
      "default": ["َ°•؟", "َ°–€", "َ°•¾"]
    },
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pavucontrol",
    "on-click-middle": "pavucontrol",
    "scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%",
    "smooth-scrolling-threshold": 0.5,
    "tooltip": true,
    "tooltip-format": "{desc} ({format_source})",
    "ignored-sinks": ["Easy Effects Sink"]
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-full": "{icon}  {capacity}%",
    "format-charging": "ïƒ§  {capacity}%",
    "format-plugged": "ï‡¦  {capacity}%",
    "format-alt": "{time}  {icon}",
    "format-icons": ["ï‰„", "ï‰ƒ", "ï‰‚", "ï‰پ", "ï‰€"]
  },

  "custom/network": {
    "exec": "/home/jllyn/.config/waybar/scripts/network.py",
    "interval": 10,
    "return-type": "json",
    "format": "{}",
    "tooltip": true,
    "on-click": "qs -p /home/jllyn/.config/quickshell/wifi.qml",
    "signal": 1
  }
}
