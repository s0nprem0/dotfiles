{
  "hyprland/workspaces": {
    "all-outputs": false,
    "warp-on-scroll": true,
    "format": "{name}",
    "persistent-only": false,
    "active-only": false,
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": []
    }
  },

  "custom/swaync": {
    "tooltip": true,
    "format": " {} {icon} ",
    "format-icons": {
      "notification": "[N]<span foreground='red'><sup>+</sup></span>",
      "none": "[N]",
      "dnd-notification": "[DND]<span foreground='red'><sup>+</sup></span>",
      "dnd-none": "[DND]",
      "inhibited-notification": "[I]<span foreground='red'><sup>+</sup></span>",
      "inhibited-none": "[I]",
      "dnd-inhibited-notification": "[DND-I]<span foreground='red'><sup>+</sup></span>",
      "dnd-inhibited-none": "[DND-I]"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "sleep 0.1 && swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },

  "hyprland/window": {
    "format": "{}",
    "rewrite": {
      "": "Desktop"
    },
    "max-length": 60,
    "ellipsize": true,
    "separate-outputs": false,
    "icon-size": 0
  },

  "tray": {
    "icon-size": 16,
    "spacing": 4,
    "show-passive-items": false,
    "expand": false
  },

  "clock": {
    "format": "{:%I:%M %p}",
    "tooltip-format": "<big>{:%Y-%m-%d %H:%M:%S}</big>",
    "interval": 1
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "¾░Øƒ  muted",
    "format-bluetooth": "¾░é» {volume}%",
    "format-bluetooth-muted": "¾░é» ¾░Øƒ",
    "format-icons": {
      "headphone": "¾░ïï",
      "hands-free": "¾░ïÄ",
      "headset": "¾░ïÄ",
      "phone": "¾░Å▓",
      "portable": "¾░Å▓",
      "car": "¾░äï",
      "default": ["¾░ò┐", "¾░ûÇ", "¾░ò¥"]
    },
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pavucontrol",
    "on-click-middle": "pavucontrol",
    "scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%",
    "smooth-scrolling-threshold": 0.5,
    "tooltip": true,
    "tooltip-format": "{desc} ({format_source})",
    "ignored-sinks": ["Easy Effects Sink"]
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-full": "{icon}  {capacity}%",
    "format-charging": "´âº  {capacity}%",
    "format-plugged": "´çª  {capacity}%",
    "format-alt": "{time}  {icon}",
    "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
  },

  "network": {
    "interval": 5,
    "format-wifi": "{icon}  {essid} ({signalStrength}%)",
    "format-ethernet": "¾░êÇ {ifname}",
    "format-disconnected": "¾░ñ»  Disconnected",
    "format-disabled": "¾░û® Wi-Fi Off",
    "format-linked": "¾░êÇ Wired (No IP)",
    "format-vpn": "´Çú VPN ({ifname})",
    "tooltip": true,
    "tooltip-format-wifi": "WiFi: {essid} ({signalStrength}%)\nIP: {ipaddr}/{cidr}\nUp: {bandwidthUpBytes} | Down: {bandwidthDownBytes}",
    "tooltip-format-ethernet": "Ethernet: {ifname}\nIP: {ipaddr}/{cidr}\nUp: {bandwidthUpBytes} | Down: {bandwidthDownBytes}",
    "tooltip-format-vpn": "VPN: {vpn_name} ({ipaddr})",
    "tooltip-format-disconnected": "No Network Connection",
    "tooltip-format-disabled": "Wi-Fi Disabled",
    "format-icons": {
      "wifi": ["¾░ñ»", "¾░ñƒ", "¾░ñó", "¾░ñÑ", "¾░ñ¿"],
      "ethernet": "¾░êÇ",
      "disconnected": "¾░ñ»",
      "disabled": "¾░û®",
      "vpn": "´Çú"
    },
    "on-click": "~/.config/waybar/scripts/wifi.sh --menu"
  }
}
