// jsonc
// NOTE: This waybar config is kept for reference only.
// Quickshell is the primary status bar. To use waybar, uncomment the hypr layer rule.
{
  "layer": "top",
  "position": "top",
  "height": 36,
  "modules-left": ["hyprland/workspaces", "hyprland/window"],
  "modules-center": ["clock"],
  "modules-right": [
    "bluetooth",
    "custom/network",
    "pulseaudio",
    "battery",
    "tray",
  ],
  "include": ["~/.config/waybar/modules.json"],
}
