@import "base.rasi"

/***** Window for bluetooth device list *****/
window {
  width: 540px;
  padding: 4px 4px 6px;
  border-radius: 0px;
}

/***** Show more rows *****/
listview {
  lines: 10;
}

/***** Element overrides *****/
element {
  padding: 12px 16px;
  border-radius: 0px;
}

element-icon {
  size: 20px;
}
