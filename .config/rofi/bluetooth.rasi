@import "/home/jllyn/.config/rofi/base.rasi"

/***** Window for bluetooth device list *****/
window {
  width: 540px;
  border-radius: 12px;
  padding: 12px 20px;
}

/***** Show more rows *****/
listview {
  lines: 10;
}

/***** Element overrides *****/
element {
  padding: 10px 14px;
  border-radius: 6px;
}

element selected.normal {
  border: 0px 0px 0px 3px;
  border-color: @selected;
}

element-icon {
  size: 20px;
}
