#!/usr/bin/env python3

from network.main import main_menu
from utils import notify

import traceback

if __name__ == "__main__":
    try:
        main_menu()
    except Exception:
        # Rofi-launched scripts can fail silently; surface the traceback.
        tb = traceback.format_exc()
        notify(
            title="Wi-Fi Manager Error",
            message=tb[-1800:],
            expire_time=10_000,
            urgency="critical",
        )
        raise
