#!/usr/bin/env bash

entries=$(ss -tulpn 2>/dev/null | tail -n +2)
[ -z "$entries" ] && { notify-send "Ports" "No listening ports found"; exit 1; }

declare -a labels=()
declare -a pids=()

while IFS= read -r line; do
  proto=$(echo "$line" | awk '{print $1}')
  local_addr=$(echo "$line" | awk '{print $5}')
  process=$(echo "$line" | awk '{print $7}')

  ip="${local_addr%:*}"
  port="${local_addr##*:}"
  if [[ "$local_addr" == \[*\]* ]]; then
    ip="${local_addr%%\]:*}"
    ip="${ip#\[}"
    port="${local_addr##*:}"
  fi

  pid=""; pname=""
  [[ "$process" =~ pid=([0-9]+) ]] && pid="${BASH_REMATCH[1]}"
  [[ "$process" =~ \"([^\"]+)\" ]] && pname="${BASH_REMATCH[1]}"
  [ -z "$pid" ] && continue

  case "$proto" in tcp|tcp6) icon="" ;; udp|udp6) icon="" ;; *) icon="" ;; esac

  labels+=("$icon  $port  $pname  ($proto $ip)")
  pids+=("$pid")
done <<< "$entries"

[ ${#labels[@]} -eq 0 ] && { notify-send "Ports" "No listening ports with PIDs found"; exit 1; }

selected_idx=$(printf '%s\n' "${labels[@]}" | rofi -dmenu -p "Ports" -format i -mesg "Select a port to kill the process" -theme ~/.config/rofi/base.rasi)
[ -z "$selected_idx" ] && exit 0

pid="${pids[$selected_idx]}"
kill -9 "$pid" 2>/dev/null
notify-send "Ports" "Killed process with PID $pid"
