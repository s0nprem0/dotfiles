{
  "$schema": "/etc/xdg/swaync/configSchema.json",

  "positionX": "right",
  "positionY": "top",
  "control-center-positionX": "right",
  "control-center-positionY": "top",
  "control-center-margin-top": 36,
  "control-center-margin-bottom": 4,
  "control-center-margin-right": 4,
  "control-center-margin-left": 0,
  "notification-placement": "next",
  "notification-inline-replies": false,
  "notification-icon-size": 32,
  "notification-body-image-height": 160,
  "notification-body-image-width": 200,
  "notification-visibility": {
    "app-name": [],
    "app-urgency-overrides": []
  },

  "timeout": 8,
  "timeout-low": 4,
  "timeout-critical": 0,
  "notification-window-width": 380,

  "layer": "overlay",
  "control-center-layer": "overlay",
  "keyboard-shortcuts": true,
  "hide-on-clear-all": false,
  "fit-to-screen": true,
  "control-center-height": 600,
  "control-center-width": 400,
  "image-capture": true,
  "notification-group": true,
  "script": {
    "notification-visibility": "",
    "notification-action": "",
    "notification-timeout": "",
    "notification-replaced": ""
  },

  "widgets": [
    "inhibitors",
    "title",
    "dnd",
    "notifications",
    "mpris",
    "buttons-grid"
  ],

  "widget-config": {
    "inhibitors": {
      "text": "Inhibitors",
      "button-text": "Clear All",
      "clear-all-button": true
    },
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": " Clear All"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "mpris": {
      "image-position": "left",
      "image-radius": 8,
      "blur": false
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "",
          "command": "kitty"
        },
        {
          "label": "",
          "command": "firefox"
        },
        {
          "label": "",
          "command": "thunar"
        },
        {
          "label": "",
          "command": "~/.config/hypr/scripts/screenshot.sh region"
        },
        {
          "label": "",
          "command": "hyprlock"
        },
        {
          "label": "",
          "command": "wlogout"
        }
      ]
    }
  }
}
