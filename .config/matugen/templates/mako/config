# ~/.config/matugen/templates/mako/config

font=FiraCode Nerd Font 10
width=350
height=150
margin=12
padding=15
border-size=2
border-radius=8

# Colors injected by Matugen
background-color={{colors.surface.default.hex}}F2
text-color={{colors.on_surface.default.hex}}
border-color={{colors.primary.default.hex}}
progress-color=over {{colors.secondary.default.hex}}

[urgency=low]
border-color={{colors.surface_variant.default.hex}}

[urgency=high]
border-color={{colors.error.default.hex}}
default-timeout=0

default-timeout=5000
