#!/usr/bin/env bash
set -uo pipefail

WALLPAPER=""
VALIDATE=false
VERBOSE=false
DRY_RUN=false
RELOAD=false
APPS=""

usage() {
    echo "Usage: $0 [OPTIONS] [WALLPAPER]"
    echo "Options:"
    echo "  --validate    Check WCAG contrast ratios"
    echo "  --verbose     Show detailed output"
    echo "  --dry-run     Preview changes without writing"
    echo "  --apps LIST   Generate only specified apps (vesktop,equibop,equicord,kitty,waybar,gtk3,gtk4,opencode,thunar,quickshell)"
    echo "  --reload      Reload quickshell after generation"
    exit 1
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --validate) VALIDATE=true; shift ;;
        --verbose) VERBOSE=true; shift ;;
        --dry-run) DRY_RUN=true; shift ;;
        --reload) RELOAD=true; shift ;;
        --apps) APPS="$2"; shift 2 ;;
        -*) usage ;;
        *) WALLPAPER="$1"; shift ;;
    esac
done

[[ -z "$WALLPAPER" ]] && { [[ -f "$HOME/.cache/quickshell/current_wallpaper" ]] && WALLPAPER=$(cat "$HOME/.cache/quickshell/current_wallpaper"); }
[[ -z "$WALLPAPER" ]] && { echo "Error: No wallpaper specified" >&2; exit 1; }
[[ ! -f "$WALLPAPER" ]] && { echo "Error: $WALLPAPER not found" >&2; exit 1; }

log() { [[ "$VERBOSE" == "true" ]] && echo "[$(date '+%H:%M:%S')] $*"; }

log "Generating theme from: $WALLPAPER"
[[ "$DRY_RUN" == "true" ]] && log "Dry run mode"

matugen image "$WALLPAPER" --prefer darkness --quiet || { echo "Error: matugen failed" >&2; exit 1; }

MATUGEN_COLORS="$HOME/.cache/quickshell/colors.json"
[[ ! -f "$MATUGEN_COLORS" ]] && { echo "Error: colors.json not found" >&2; exit 1; }

get_color() { jq -r ".${1}" "$MATUGEN_COLORS"; }
get_hex() { printf '%s' "${1#\#}"; }
get_rgb() { local h="${1#\#}"; printf '%d,%d,%d' "0x${h:0:2}" "0x${h:2:2}" "0x${h:4:2}"; }

# Get colors
BG=$(get_color "bg")
FG=$(get_color "fg")
PRIMARY=$(get_color "primary")
ERROR=$(get_color "error")
SURFACE=$(get_color "surface")
SURFACE_LIGHTER=$(get_color "surfaceLighter")
GREEN=$(get_color "green" 2>/dev/null || echo "$PRIMARY")
WARNING=$(get_color "warning" 2>/dev/null || echo "$PRIMARY")
BLUE=$(get_color "blue" 2>/dev/null || echo "$PRIMARY")

# Hex values
BG_HEX=$(get_hex "$BG")
FG_HEX=$(get_hex "$FG")
PRIMARY_HEX=$(get_hex "$PRIMARY")
ERROR_HEX=$(get_hex "$ERROR")
SURFACE_HEX=$(get_hex "$SURFACE")
SURFACE_LIGHTER_HEX=$(get_hex "$SURFACE_LIGHTER")
GREEN_HEX=$(get_hex "$GREEN")
WARNING_HEX=$(get_hex "$WARNING")
BLUE_HEX=$(get_hex "$BLUE")

# RGB values
BG_RGB=$(get_rgb "$BG")
FG_RGB=$(get_rgb "$FG")
PRIMARY_RGB=$(get_rgb "$PRIMARY")
SURFACE_RGB=$(get_rgb "$SURFACE")
SURFACE_LIGHTER_RGB=$(get_rgb "$SURFACE_LIGHTER")
GREEN_RGB=$(get_rgb "$GREEN")
WARNING_RGB=$(get_rgb "$WARNING")
BLUE_RGB=$(get_rgb "$BLUE")

# Derived values
SECONDARY="$FG"; SECONDARY_HEX="$FG_HEX"; SECONDARY_RGB="$FG_RGB"
BG_DARK="$SURFACE"; BG_DARK_HEX="$SURFACE_HEX"; BG_DARK_RGB="$SURFACE_RGB"
BG_LIGHT="$SURFACE_LIGHTER"; BG_LIGHT_HEX="$SURFACE_LIGHTER_HEX"; BG_LIGHT_RGB="$SURFACE_LIGHTER_RGB"
FG_LIGHT="$FG"; FG_LIGHT_HEX="$FG_HEX"; FG_LIGHT_RGB="$FG_RGB"
MUTED="$FG"; MUTED_HEX="$FG_HEX"; MUTED_RGB="$FG_RGB"

should_generate() { [[ -z "$APPS" ]] || echo "$APPS" | grep -q "$1"; }

generate_template() {
    sed -e "s|{{accent_hex}}|$PRIMARY_HEX|g" \
        -e "s|{{accent_rgb}}|$PRIMARY_RGB|g" \
        -e "s|{{secondary_hex}}|$SECONDARY_HEX|g" \
        -e "s|{{secondary_rgb}}|$SECONDARY_RGB|g" \
        -e "s|{{fg_hex}}|$FG_HEX|g" \
        -e "s|{{fg_rgb}}|$FG_RGB|g" \
        -e "s|{{fg_light_hex}}|$FG_LIGHT_HEX|g" \
        -e "s|{{fg_light_rgb}}|$FG_LIGHT_RGB|g" \
        -e "s|{{bg_hex}}|$BG_HEX|g" \
        -e "s|{{bg_rgb}}|$BG_RGB|g" \
        -e "s|{{bg_dark_hex}}|$BG_DARK_HEX|g" \
        -e "s|{{bg_dark_rgb}}|$BG_DARK_RGB|g" \
        -e "s|{{bg_light_hex}}|$BG_LIGHT_HEX|g" \
        -e "s|{{bg_light_rgb}}|$BG_LIGHT_RGB|g" \
        -e "s|{{error_hex}}|$ERROR_HEX|g" \
        -e "s|{{green_hex}}|$GREEN_HEX|g" \
        -e "s|{{warning_hex}}|$WARNING_HEX|g" \
        -e "s|{{blue_hex}}|$BLUE_HEX|g" \
        -e "s|{{surface_hex}}|$SURFACE_HEX|g" \
        -e "s|{{primary_hex}}|$PRIMARY_HEX|g" \
        -e "s|{{muted_hex}}|$MUTED_HEX|g" \
        -e "s|{{muted_rgb}}|$MUTED_RGB|g" \
        "$1"
}

[[ "$DRY_RUN" == "true" ]] && generate_template "$HOME/.config/matugen/templates/apps/vesktop.css.template"

if should_generate "vesktop"; then
    for d in vesktop equibop Equicord; do
        [[ -d "$HOME/.config/$d/settings" ]] && \
        generate_template "$HOME/.config/matugen/templates/apps/vesktop.css.template" > "$HOME/.config/$d/settings/quickCss.css" && \
        echo "Updated $d theme"
    done
fi

if should_generate "kitty"; then
    [[ -d "$HOME/.config/kitty" ]] && \
    generate_template "$HOME/.config/matugen/templates/apps/kitty.conf.template" > "$HOME/.config/kitty/colors.conf" && \
    echo "Updated kitty theme"
fi

if should_generate "waybar"; then
    [[ -d "$HOME/.config/waybar" ]] && \
    generate_template "$HOME/.config/matugen/templates/apps/waybar.css.template" > "$HOME/.config/waybar/style.css" && \
    echo "Updated waybar theme"
fi

if should_generate "gtk3"; then
    [[ -d "$HOME/.config/gtk-3.0" ]] && \
    generate_template "$HOME/.config/matugen/templates/apps/gtk3-colors.css.template" > "$HOME/.config/gtk-3.0/colors.css" && \
    echo "Updated gtk3 theme"
fi

if should_generate "gtk4"; then
    [[ -d "$HOME/.config/gtk-4.0" ]] && \
    generate_template "$HOME/.config/matugen/templates/apps/gtk4-colors.css.template" > "$HOME/.config/gtk-4.0/colors.css" && \
    echo "Updated gtk4 theme"
fi

if should_generate "opencode"; then
    mkdir -p "$HOME/.config/opencode/themes"
    cat > "$HOME/.config/opencode/themes/matugen.json" << EOF
{
  "\$schema": "https://opencode.ai/theme.json",
  "defs": {
    "matugen_bg": "$BG",
    "matugen_bg_dark": "$SURFACE",
    "matugen_bg_light": "$SURFACE_LIGHTER",
    "matugen_fg": "$FG",
    "matugen_fg_light": "$FG_LIGHT",
    "matugen_accent": "$PRIMARY",
    "matugen_secondary": "$SECONDARY",
    "matugen_tertiary": "$SURFACE",
    "matugen_error": "$ERROR"
  },
  "theme": {
    "primary":              { "dark": "matugen_accent",     "light": "matugen_accent" },
    "secondary":            { "dark": "matugen_secondary",   "light": "matugen_secondary" },
    "accent":               { "dark": "matugen_tertiary",    "light": "matugen_tertiary" },
    "error":                { "dark": "matugen_error",       "light": "matugen_error" },
    "text":                 { "dark": "matugen_fg",          "light": "matugen_fg" },
    "background":           { "dark": "matugen_bg",          "light": "matugen_bg" }
  }
}
EOF
    echo "Updated opencode theme"
fi

if should_generate "thunar"; then
    if [[ "$DRY_RUN" == "true" ]]; then
        echo "Would run: rebuild_thunar.sh"
    else
        ~/.local/bin/rebuild_thunar.sh 2>/dev/null || "$HOME/.local/share/bin/rebuild_thunar.sh" 2>/dev/null || \
        bash "$HOME/dotfiles/scripts/rebuild_thunar.sh" 2>/dev/null || \
        echo "Warning: rebuild_thunar.sh not found"
    fi
fi

if [[ "$RELOAD" == "true" ]]; then
    log "Reloading quickshell..."
    quickshell --reload 2>/dev/null || echo "Warning: Failed to reload quickshell"
fi

log "Theme generation complete!"